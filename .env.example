# —— Backend (Vercel / serverless) — never commit real keys; use Vercel env or local .env only
CLAUDE_API_KEY=your_anthropic_key_from_console
JWT_SECRET=at_least_32_random_characters_generate_with_openssl

# Postgres — Neon exports these names from the dashboard (pooled vs direct).
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POOLER_HOST.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@YOUR_DIRECT_HOST.neon.tech/neondb?sslmode=require
#
# If you use Vercel’s Neon integration, map POSTGRES_PRISMA_URL → DATABASE_URL
# and POSTGRES_URL_NON_POOLING → DATABASE_URL_UNPOOLED in the Vercel env UI.

# Stripe (secret + webhook signing secret only on server — use test keys until launch)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxx

# Public app URL (no trailing slash) — used in Checkout / Billing Portal / password reset links
APP_URL=https://your-app.vercel.app

# Password reset emails (Resend — https://resend.com). Optional in local dev (API returns devResetUrl instead).
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=AI Renamer <onboarding@resend.dev>

# —— Frontend (Vite) — VITE_* is exposed to the browser
VITE_API_URL=/api
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
VITE_STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
VITE_STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxx
